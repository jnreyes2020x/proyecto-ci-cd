{
  "name": "proyecto-ci-cd",
  "version": "1.0.0",
  "description": "Proyecto Node.js con pipeline CI/CD usando GitHub Actions",
  "main": "src/calculadora.js",
  "scripts": {
    "test": "jest --coverage",
    "lint": "eslint src/ tests/"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "functions": 80,
        "branches": 80,
        "statements": 80
      }
    }
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0"
  }
}
